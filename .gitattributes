# Force LF line endings on test fixtures. The TSV loader in
# ts/test/tsv.test.ts splits on /\r?\n/ defensively, but other tooling
# (aontu/jsonic parsers, diff readers, snapshot tests) is line-ending
# sensitive too; keep the canonical form stable across platforms.
*.tsv text eol=lf
*.aontu text eol=lf
